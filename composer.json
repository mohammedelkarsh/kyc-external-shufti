{
    "name": "kyc-ai/external-shufti",
    "version": "1.0.0",
    "description": "Shufti Pro external verification driver for kyc-ai/laravel.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mohammedelkarsh/kyc-external-shufti",
    "support": {
        "issues": "https://github.com/mohammedelkarsh/kyc-external-shufti/issues",
        "source": "https://github.com/mohammedelkarsh/kyc-external-shufti"
    },
    "keywords": [
        "laravel",
        "kyc",
        "shufti",
        "identity",
        "verification"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "kyc-ai/laravel": "^1.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.5",
        "validators/ae": "^1.0",
        "validators/eg": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "KycAi\\ExternalShufti\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KycAi\\ExternalShufti\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KycAi\\ExternalShufti\\ShuftiServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
